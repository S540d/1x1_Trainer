# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
testing/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision

# Build outputs (can be downloaded from EAS)
*.aab
*.apk
builds/

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Old native Android project (kept for reference)
Android_old/

# Keystore directory with signing keys
Keystore/

# Local GitHub templates (from .templates submodule)
# Only track via submodule, ignore local copies
.github/ISSUE_TEMPLATE/
.github/PULL_REQUEST_TEMPLATE/
Android/app/release/
Android/playstore-screenshots/
Android/release/
credentials.json
test-results/

# Test coverage
coverage/

# Local-only files (not for public repo — Issue #150)
.claude/
docs/ANDROID_BUILD.md
docs/RELEASE_CHECKLIST.md
scripts/setup-twa-step1.sh

# Private documentation (local only — Issue #152)
docs/private/

# Play Store / Marketing assets (local only — not for public repo)
public/Gemini_Generated_Image_*
public/Vorstellungsgrafik*.png
public/1x1 Trainer.png
public/1x1_trainer_graphic.*
public/screenshot*.png
public/screenshot2.png
public/favicon-new.png
playstore-screenshots/

# Security – Pflicht-Einträge (Issue #7 / reusable-gitignore-audit)
.env.local
